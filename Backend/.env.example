# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Base de datos PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sysdept

# Uploads
DIRECTORIO_UPLOADS=./uploads
TAMANO_MAX_ARCHIVO_MB=50

# Servidor
PUERTO_API=8000
ORIGENES_PERMITIDOS=["http://localhost:5173"]

# Agentes
MODELO_AGENTE=claude-sonnet-4-6
MAX_TOKENS_AGENTE=2000
TURNOS_ANALISIS_INICIAL=6
TURNOS_MAX_CONVERSACION=8
VENTANA_HISTORIAL_MENSAJES=20
MAX_REINTENTOS_AGENTE=2
SEGUNDOS_ESPERA_REINTENTO=3
